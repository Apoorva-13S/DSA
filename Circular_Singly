void search(int val){
   if(head==NULL){
        printf("List is empty\n");
    }
    else{
        struct Node* temp = head;
        do{
            if(temp->data == val){
                printf("Found\n");
                return;
            }
            temp=temp->next;
        }
        while(temp!=head);
        printf("Data not found :/");
    }
}
void display(){
    if(head==NULL){
        printf("List is empty\n");
    }
    else{
        struct Node* temp = head;
        do{
            printf("%d ",temp->data);
            temp=temp->next;
        }
        while(temp!=head);
        printf("\n");
    }
}
