#include<stdio.h>
#include<stdlib.h>
#define max 100
int tree[max], idx =0;
void initialise(){                                           //initialise only when you have to insert values less than the size.
    for( int i=0 ; i<max; i++){
        tree[i]=-1;
    }
}
void insert(int val){                                       //Here we are inserting data in BT using level order
    if(idx==max)
        printf("Tree is full");
    else
        tree[idx++] =val;
}
void levelorder(){
    if(idx==0)
         printf("Tree is empty !!\n");
    else{
        for(int i=0;i<idx;i++){
            if(tree[i] != -1)
               printf("%d ",tree[i]);
        }
    }
}
void preorder(int index){                                 //Root->Left->Right
    if(tree[index]==-1 || index >= max)
        return;
    printf("%d ",tree[index]);
    preorder(2*index+1);
    preorder(2*index+2);
}
void inorder(int index){                                  //Left->Root->Right
    if(tree[index]==-1 || index >= max)
        return;
    preorder(2*index+1);
    printf("%d ",tree[index]);
    preorrder(2*index+2);
}
void postorder(int index){                                   //Left->Right->Root
    if(tree[index]==-1 || index >= max)
        return;
    preorder(2*index+1);
    preorrder(2*index+2);
    printf("%d ",tree[index]);
}
int main(){
    int choice,value;
    initialise();
    while(1){
        printf("\n____-___Binary Tree Menu___-____\n");
        printf("1. Insert\n");
        printf("2. Level order Traversal\n");
        printf("3. Pre-order Traversal\n");
        printf("4. In-order Traversal\n");
        printf("5. Post-order Traversal\n");
        printf("6. Exit\n");
        printf("Enter choice : ");
        scanf("%d",&choice);
        switch(choice){
            case 1:
              printf("Enter data to be inserted: ");
              scanf("%d",&value);
              insert(value);
              break;
            case 2:
              levelorder();
              break;
            case 3:
              preorder(0);
              break;
            case 4:
              inorder(0);
              break;
            case 5:
              postorder(0);
              break;
            case 6:
              exit(0);
              break;
            default:
              printf("Invalid choice!!\n");
        }
    }
}
